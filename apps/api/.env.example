# ── Application ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# The URL of the Next.js frontend (used for CORS allow-list)
# Comma-separate multiple origins: http://localhost:3000,https://app.example.com
CORS_ORIGIN=http://localhost:3000

# ── MS SQL Server ──────────────────────────────────────────────────────────────
DB_SERVER=localhost
DB_PORT=1433
DB_NAME=ProjectFlow
DB_USER=sa
DB_PASSWORD=YourStrong@Passw0rd
# Set to "true" to enforce TLS on the SQL connection (required in production)
DB_ENCRYPT=false
# Set to "false" in production when using a valid CA-signed certificate
DB_TRUST_SERVER_CERTIFICATE=true

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ────────────────────────────────────────────────────────────────────────
# REQUIRED in production — generate with: openssl rand -hex 32
# Must NOT use the default value in production (server will refuse to start)
JWT_SECRET=change-this-secret-in-production
# Access token lifetime (jsonwebtoken format: 15m, 1h, 7d …)
JWT_EXPIRES_IN=15m

# ── MinIO / S3-compatible storage ──────────────────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=projectflow

# ── Email (BullMQ notification worker) ────────────────────────────────────────
# SMTP credentials for outgoing notification emails
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@example.com
SMTP_PASS=your-smtp-password
EMAIL_FROM="ProjectFlow <noreply@example.com>"

# ── Admin ──────────────────────────────────────────────────────────────────────
# Comma-separated user IDs that have admin panel access
# Find a userId after registering the first user via GET /api/v1/auth/me
ADMIN_USER_IDS=

# ── OAuth sign-in (Phase 1.A — Google) ────────────────────────────────────────
# Leave EVERY *_CLIENT_ID / *_CLIENT_SECRET pair empty to disable social
# sign-in entirely. /api/v1/auth/oauth/providers will return [] and the
# login page hides the social section. The server boots cleanly either way.
#
# Google setup (https://console.cloud.google.com/apis/credentials):
#   1. Create an OAuth 2.0 Client ID, type "Web application".
#   2. Add this exact callback to "Authorized redirect URIs":
#        ${OAUTH_REDIRECT_BASE_URL}/api/v1/auth/oauth/google/callback
#      (e.g. http://localhost:3001/api/v1/auth/oauth/google/callback for dev).
#   3. Add http://localhost:3000 to "Authorized JavaScript origins".
#   4. Paste the Client ID and Client Secret below.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Absolute base URL the provider should redirect callbacks to. Defaults to
# http://localhost:${PORT} when unset. Override in production to your
# public API origin.
OAUTH_REDIRECT_BASE_URL=

# Front-end origin we redirect the user back to after the callback runs.
# Defaults to the first CORS_ORIGIN entry. Override in production if your
# auth-finish page lives on a different host than your API allow-list.
OAUTH_FINISH_BASE_URL=
