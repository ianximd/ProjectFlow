{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"],
    "esModuleInterop": true,
    "outDir": "./dist-scripts"
  },
  "include": ["scripts/**/*.ts"],
  "exclude": ["node_modules", "apps", "packages", "projectflow"]
}
