# ── Application ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# The URL of the Next.js frontend (used for CORS allow-list)
# Comma-separate multiple origins: http://localhost:3000,https://app.example.com
CORS_ORIGIN=http://localhost:3000

# ── Logging (Phase 6 W43 — structured pino logger) ────────────────────────────
# trace | debug | info | warn | error | fatal | silent
# Defaults: 'info' (production), 'debug' (development), 'silent' (NODE_ENV=test)
# In development NODE_ENV, output uses pino-pretty (coloured, terminal-friendly).
# In production NODE_ENV, output is raw JSON suitable for log shippers.
LOG_LEVEL=

# ── MS SQL Server ──────────────────────────────────────────────────────────────
DB_SERVER=
DB_PORT=
DB_NAME=
DB_USER=
DB_PASSWORD=
# Set to "true" to enforce TLS on the SQL connection (required in production)
DB_ENCRYPT=false
# Set to "false" in production when using a valid CA-signed certificate
DB_TRUST_SERVER_CERTIFICATE=true

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ────────────────────────────────────────────────────────────────────────
# REQUIRED in production — generate with: openssl rand -hex 32
# Must NOT use the default value in production (server will refuse to start)
JWT_SECRET=aa4ffab760f382388b6aad23e0003bdc7b3e3a5c41d5e422d7d182ce244e75f5e53c78c7850eb1c9605cd3e968852f8dbceb9a1d33d7134f5086a9a89622270b3f1284546ef16fddeda0afd056d934f0c8679d5947994cc3514a55d94a10a97207e0211ae5316190f903f57db60af7cf3af3a7387d52b47f927c610079e18993
# Access token lifetime (jsonwebtoken format: 15m, 1h, 7d …)
JWT_EXPIRES_IN=15m

# ── BFF (server-to-server) ──────────────────────────────────────────────────────
# Shared secret the Next.js server (apps/next-web) sends in the X-BFF-Secret
# header. When it matches, the API returns the rotating refresh token in the
# login/refresh response body so Next can own the httpOnly session cookies.
# MUST be identical to next-web's BFF_SECRET. In development it falls back to
# "devsecret" if unset; set a strong, matching secret in production.
BFF_SECRET=devsecret

# ── MinIO / S3-compatible storage ──────────────────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=projectflow

# ── Email (BullMQ notification worker) ────────────────────────────────────────
# SMTP credentials for outgoing notification emails
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@example.com
SMTP_PASS=your-smtp-password
EMAIL_FROM="ProjectFlow <noreply@example.com>"

# ── Admin ──────────────────────────────────────────────────────────────────────
# Comma-separated user IDs that have admin panel access
# Find a userId after registering the first user via GET /api/v1/auth/me
ADMIN_USER_IDS=

# ── OAuth sign-in (Phase 1.A — Google) ────────────────────────────────────────
# Leave EVERY *_CLIENT_ID / *_CLIENT_SECRET pair empty to disable social
# sign-in entirely. /api/v1/auth/oauth/providers will return [] and the
# login page hides the social section. The server boots cleanly either way.
#
# Google setup (https://console.cloud.google.com/apis/credentials):
#   1. Create an OAuth 2.0 Client ID, type "Web application".
#   2. Add this exact callback to "Authorized redirect URIs":
#        ${OAUTH_REDIRECT_BASE_URL}/api/v1/auth/oauth/google/callback
#      (e.g. http://localhost:3001/api/v1/auth/oauth/google/callback for dev).
#   3. Add http://localhost:3000 to "Authorized JavaScript origins".
#   4. Paste the Client ID and Client Secret below.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# GitHub setup (https://github.com/settings/developers → OAuth Apps → New):
#   1. Authorization callback URL:
#        ${OAUTH_REDIRECT_BASE_URL}/api/v1/auth/oauth/github/callback
#   2. Generate a client secret and paste both below.
# Note: GitHub OAuth Apps don't support PKCE — the flow relies on the
# secret. We request the `user:email` scope so we can fall back to
# /user/emails when the user's primary email is set to private.
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# Microsoft setup (https://portal.azure.com → App registrations → New):
#   1. Supported account types: "Accounts in any organizational directory
#      and personal Microsoft accounts" (matches the default tenant
#      below). Choose "Accounts in this organizational directory only"
#      if you want enterprise SSO; then set MICROSOFT_OAUTH_TENANT to
#      the tenant GUID.
#   2. Redirect URI (Web):
#        ${OAUTH_REDIRECT_BASE_URL}/api/v1/auth/oauth/microsoft/callback
#   3. Certificates & secrets → New client secret → paste below.
#   4. API permissions → add `User.Read` (delegated, default Microsoft
#      Graph permission). Grant admin consent if you locked to a tenant.
# We use the directory `oid` (Graph /me id), NOT the OIDC `sub`, because
# `sub` is tenant-scoped on `common` — the same human gets a different
# `sub` from work vs personal accounts.
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
# 'common' (default) | 'organizations' | 'consumers' | <tenant GUID>
MICROSOFT_OAUTH_TENANT=common

# Absolute base URL the provider should redirect callbacks to. Defaults to
# http://localhost:${PORT} when unset. Override in production to your
# public API origin.
OAUTH_REDIRECT_BASE_URL=

# Front-end origin we redirect the user back to after the callback runs.
# Defaults to the first CORS_ORIGIN entry. Override in production if your
# auth-finish page lives on a different host than your API allow-list.
OAUTH_FINISH_BASE_URL=

# ── OAuth token encryption (Phase 1.D — at-rest) ──────────────────────────────
# Optional. When set, the API encrypts the access/refresh tokens it
# receives from Google / GitHub / Microsoft using AES-256-GCM and stores
# the ciphertext on UserOAuthIdentities. Leave _PRIMARY unset to skip
# persistence entirely (sign-in still works; token-using features like a
# future Drive integration just won't have anything to call out with).
#
# Setup + key rotation procedure: docs/runbooks/oauth-key-rotation.md
#
# Generate a key with:   openssl rand -base64 32
# Key id format:         [A-Za-z0-9_]{1,16}  (convention: v1, v2, ...)
OAUTH_TOKEN_ENC_KEY_PRIMARY=
OAUTH_TOKEN_ENC_KEY_v1=
