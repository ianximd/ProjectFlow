# ── Application ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# The URL of the Next.js frontend (used for CORS allow-list)
# Comma-separate multiple origins: http://localhost:3000,https://app.example.com
CORS_ORIGIN=http://localhost:3000

# ── MS SQL Server ──────────────────────────────────────────────────────────────
DB_SERVER=localhost
DB_PORT=1433
DB_NAME=ProjectFlow
DB_USER=sa
DB_PASSWORD=YourStrong@Passw0rd
# Set to "true" to enforce TLS on the SQL connection (required in production)
DB_ENCRYPT=false
# Set to "false" in production when using a valid CA-signed certificate
DB_TRUST_SERVER_CERTIFICATE=true

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ────────────────────────────────────────────────────────────────────────
# REQUIRED in production — generate with: openssl rand -hex 32
# Must NOT use the default value in production (server will refuse to start)
JWT_SECRET=change-this-secret-in-production
# Access token lifetime (jsonwebtoken format: 15m, 1h, 7d …)
JWT_EXPIRES_IN=15m

# ── MinIO / S3-compatible storage ──────────────────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=projectflow

# ── Email (BullMQ notification worker) ────────────────────────────────────────
# SMTP credentials for outgoing notification emails
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@example.com
SMTP_PASS=your-smtp-password
EMAIL_FROM="ProjectFlow <noreply@example.com>"

# ── Admin ──────────────────────────────────────────────────────────────────────
# Comma-separated user IDs that have admin panel access
# Find a userId after registering the first user via GET /api/v1/auth/me
ADMIN_USER_IDS=
