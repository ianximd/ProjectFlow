# App
NODE_ENV=development
PORT=3001
APP_URL=http://localhost:3001

# MS SQL Server
DB_SERVER=localhost
DB_PORT=1433
DB_NAME=ProjectFlow
DB_USER=sa
DB_PASSWORD=YourStrong@Passw0rd
DB_ENCRYPT=false
DB_TRUST_SERVER_CERTIFICATE=true

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=your-256-bit-secret-here-change-this-in-production
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=another-256-bit-secret-change-this-in-production
REFRESH_TOKEN_EXPIRES_IN=7d

# OAuth (Optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Storage - MinIO (Local Development)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=projectflow-files

# Email (Optional)
RESEND_API_KEY=
EMAIL_FROM=noreply@projectflow.local

# Frontend
FRONTEND_URL=http://localhost:3000

# Sentry (Optional)
SENTRY_DSN=